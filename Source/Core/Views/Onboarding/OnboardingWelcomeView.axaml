<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Core.Resources="clr-namespace:Core.Resources;assembly=Core.Resources"

    x:Class="Core.Views.Onboarding.OnboardingWelcomeView"
    
    mc:Ignorable="d"
    d:DesignWidth="1250"
    d:DesignHeight="700">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" Spacing="15" Margin="0 0 0 -30">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Height="85" HorizontalAlignment="Center"
                       Source="/Assets/Icon/App.Icon.png" Margin="0 0 0 40"/>
            </Grid>
            
            <TextBlock LineSpacing="0" FontWeight="Bold" LetterSpacing="-1" HorizontalAlignment="Center" FontSize="100" Foreground="#f5f5f5">
                Welcome.
            </TextBlock>

            <Button
                Classes="GlassWhite HoverLift"
                Margin="0 50 0 0"
                Click="OnStartClicked"
                Cursor="Hand"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                HorizontalAlignment="Center"
                Padding="25 15"
                ClipToBounds="True"
                FontWeight="SemiBold"
                CornerRadius="5"
                IsDefault="True">
                
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Margin="0 1 0 0" Text="Get Started" FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
